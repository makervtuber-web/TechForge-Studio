<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16">
  <defs>
    <linearGradient id="techGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#00f3ff;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#ff003c;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#39ff14;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="16" height="16" fill="#000000" rx="3"/>
  
  <!-- Simplified TechForge Logo for 16x16 -->
  <g transform="translate(8, 8)">
    <!-- Outer hexagon frame -->
    <path d="M -5,-3 L -3,-5 L 3,-5 L 5,-3 L 5,3 L 3,5 L -3,5 L -5,3 Z" 
          fill="none" 
          stroke="url(#techGradient)" 
          stroke-width="1" 
          opacity="0.8"/>
    
    <!-- Center dot -->
    <circle cx="0" cy="0" r="1" fill="#ff003c"/>
    
    <!-- Corner elements -->
    <g fill="#00f3ff" opacity="0.7">
      <rect x="-4" y="-0.5" width="1" height="1"/>
      <rect x="3" y="-0.5" width="1" height="1"/>
      <rect x="-0.5" y="-4" width="1" height="1"/>
      <rect x="-0.5" y="3" width="1" height="1"/>
    </g>
  </g>
</svg>
