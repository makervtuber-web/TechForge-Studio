<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192 192" width="192" height="192">
  <defs>
    <linearGradient id="techGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#00f3ff;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#ff003c;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#39ff14;stop-opacity:1" />
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="4" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="192" height="192" fill="#000000" rx="24"/>
  
  <!-- TechForge Logo - Geometric Design -->
  <g transform="translate(96, 96)" filter="url(#glow)">
    <!-- Outer hexagon frame -->
    <path d="M -60,-36 L -36,-60 L 36,-60 L 60,-36 L 60,36 L 36,60 L -36,60 L -60,36 Z" 
          fill="none" 
          stroke="url(#techGradient)" 
          stroke-width="4" 
          opacity="0.8"/>
    
    <!-- Inner circuit pattern -->
    <g stroke="#00f3ff" stroke-width="3" fill="none" opacity="0.9">
      <line x1="-36" y1="0" x2="-12" y2="0"/>
      <line x1="12" y1="0" x2="36" y2="0"/>
      <line x1="0" y1="-36" x2="0" y2="-12"/>
      <line x1="0" y1="12" x2="0" y2="36"/>
      <circle cx="0" cy="0" r="12" fill="#ff003c"/>
    </g>
    
    <!-- Tech elements -->
    <g fill="url(#techGradient)" opacity="0.7">
      <rect x="-48" y="-6" width="12" height="12" rx="2"/>
      <rect x="36" y="-6" width="12" height="12" rx="2"/>
      <rect x="-6" y="-48" width="12" height="12" rx="2"/>
      <rect x="-6" y="36" width="12" height="12" rx="2"/>
    </g>
    
    <!-- Center emblem -->
    <text x="0" y="8" text-anchor="middle" 
          font-family="Orbitron, monospace" 
          font-size="32" 
          font-weight="900" 
          fill="#39ff14">TF</text>
    
    <!-- TechForge text -->
    <text x="0" y="80" text-anchor="middle" 
          font-family="Orbitron, monospace" 
          font-size="14" 
          font-weight="500" 
          fill="#00f3ff"
          opacity="0.8">TECHFORGE</text>
  </g>
</svg>
